---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Card from '../components/Card.astro';
---
<Layout title="Checklist chuẩn bị đám cưới — Thiệp Cưới Online" description="Checklist chuẩn bị đám cưới theo mốc thời gian.">
  <PageHero eyebrow="Lên kế hoạch" title="Checklist chuẩn bị đám cưới" lead="Nhập ngày cưới để xem các việc cần làm theo từng mốc thời gian." />
  <Card class="mx-auto mb-4 max-w-[760px]">
    <label class="block">
      <span class="text-sm text-brand-muted">Ngày cưới</span>
      <input id="weddingDate" type="date" class="mt-1 w-full rounded-lg border border-line bg-paper-2 px-3 py-2" />
    </label>
    <p id="progress" class="mt-3 text-center font-semibold text-gold-deep"></p>
  </Card>
  <div id="out" class="mx-auto mb-16 max-w-[760px]"></div>
  <script>import '../scripts/checklist';</script>
</Layout>

<style is:global>
  @keyframes progressPulse {
    0%   { transform: scale(1); }
    30%  { transform: scale(1.06); color: var(--color-gold-deep); }
    100% { transform: scale(1); }
  }
  #progress.progress-tick { animation: progressPulse .3s ease both; }
  @media (prefers-reduced-motion: reduce) { #progress.progress-tick { animation: none; } }
  .cl-phase {
    margin-bottom: 22px;
  }
  .cl-phase-title {
    font-family: var(--font-display);
    font-size: 19px;
    margin: 0 0 10px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--color-line);
    animation: clItemIn .22s ease both;
  }
  @keyframes clItemIn { from { opacity: 0; transform: translateY(-5px); } to { opacity: 1; transform: none; } }
  .cl-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 14px;
    border: 1px solid var(--color-line);
    border-radius: 12px;
    background: var(--color-paper-2, #faf9f7);
    margin-bottom: 8px;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s, transform 0.15s;
    animation: clItemIn .22s ease both;
  }
  @media (prefers-reduced-motion: reduce) { .cl-item { animation: none; } }
  .cl-item:hover {
    border-color: var(--color-gold);
  }
  .cl-item[data-done] {
    background: #f0f8f1;
    border-color: #bfe3c6;
    animation: clItemCheck .35s cubic-bezier(.22,.61,.36,1) both;
  }
  @keyframes clItemCheck {
    0%   { transform: scale(1); }
    40%  { transform: scale(.97); }
    70%  { transform: scale(1.025); }
    100% { transform: scale(1); }
  }
  .cl-item[data-done] .cl-text {
    text-decoration: line-through;
    color: var(--color-brand-muted, #888);
  }
  .cl-check {
    width: 20px;
    height: 20px;
    accent-color: var(--color-gold-deep);
    flex: none;
  }
  .cl-text {
    flex: 1;
    font-size: 15px;
  }
  .cl-link {
    color: var(--color-gold-deep);
    font-weight: 600;
    text-decoration: none;
  }
  .cl-due {
    font-size: 12px;
    color: var(--color-brand-muted, #888);
    white-space: nowrap;
  }
  .cl-due[data-overdue] {
    color: var(--color-red, #d9534f);
    font-weight: 600;
  }
</style>
