---
// Builder shell. Form UI rebuilt with Starwind components + progressive-disclosure
// accordion; legacy editor.js island is untouched (all ids/names/data-attrs preserved).
import '../styles/global.css';
import Label from '../components/starwind/label/Label.astro';
import Input from '../components/starwind/input/Input.astro';
import Textarea from '../components/starwind/textarea/Textarea.astro';
import Select from '../components/starwind/select/Select.astro';
import Accordion from '../components/starwind/accordion/Accordion.astro';
import AccordionItem from '../components/starwind/accordion/AccordionItem.astro';
import Button from '../components/starwind/button/Button.astro';
import {
  LayoutTemplate, ListChecks, ScrollText, CalendarHeart, Gift, Wallet,
  Heart, Images, CalendarClock, House, Sparkles, WandSparkles, ImagePlus,
} from 'lucide-astro';
---
<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22%3E%3Ctext y=%22.9em%22 font-size=%2290%22%3E💌%3C/text%3E%3C/svg%3E" />
  <title>Thiệp Cưới Online — Tự tạo thiệp cưới đẹp trong vài phút</title>
  <meta name="description" content="Tạo thiệp cưới online miễn phí cho người Việt: nhiều mẫu đẹp, đếm ngược ngày cưới, bản đồ chỉ đường và xác nhận tham dự (RSVP)." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700;800&family=Great+Vibes&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/base.css" />
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="theme-color" content="#b5232a" />
  <style is:global>
    /* ── Home · airy refinements (this page only) ─────────────────────── */
    body {
      background:
        radial-gradient(58% 46% at 50% -6%, #fbeede 0%, transparent 62%),
        #fdfcfb;
    }
    .wrap { max-width: 1200px; }

    /* Header — light, line-icon nav (replaces heavy white pills) */
    .site-header { padding: 18px 0; }
    .brand .sigil { box-shadow: 0 8px 20px -10px rgba(181, 35, 42, .5); }
    .site-nav { display: flex; gap: 3px; align-items: center; flex-wrap: wrap; }
    .nav-link {
      display: inline-flex; align-items: center; gap: 7px;
      padding: 8px 12px; border-radius: 10px;
      font-size: 14px; font-weight: 500; line-height: 1;
      color: #6f635a; text-decoration: none;
      transition: background .15s, color .15s;
    }
    .nav-link svg { opacity: .7; }
    .nav-link:hover { background: #f4eee7; color: var(--ink); }
    .nav-link:hover svg { opacity: 1; }
    .nav-cta {
      background: var(--red); color: #fff; font-weight: 600; padding: 9px 16px;
      box-shadow: 0 8px 20px -10px rgba(181, 35, 42, .5);
    }
    .nav-cta:hover { background: #9c171d; color: #fff; }

    /* Hero — more air, refined accents */
    .hero { padding: 64px 0 46px; }
    .hero .eyebrow { color: var(--gold-deep); letter-spacing: 3px; font-weight: 600; }
    .hero p { color: #6f635a; }
    .hero-cta { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-top: 22px; }
    .hero-trust { color: #94867c; margin-top: 22px; }

    /* Buttons — unify CTAs on brand red (drop muddy gold), align icons */
    .hero .btn { display: inline-flex; align-items: center; gap: 8px; }
    .hero .btn svg { flex: 0 0 auto; }
    .hero .btn-primary {
      background: var(--red); color: #fff;
      box-shadow: 0 12px 28px -12px rgba(181, 35, 42, .5);
    }
    .hero .btn-primary:hover { background: #9c171d; }
    .hero .btn-ghost { background: #fff; border-color: #ecdcca; color: var(--ink); }
    .hero .btn-ghost:hover { border-color: var(--gold); color: var(--ink); }
    .draft-toast { opacity: 0; transform: translateX(-50%) translateY(8px); transition: opacity .2s, transform .2s; }
    .draft-toast--show { opacity: 1; transform: translateX(-50%) translateY(0); }
  </style>
</head>
<body>
  <div class="wrap">
    <header class="site-header">
      <a class="brand" href="/">
        <span class="sigil">囍</span>
        <span><b>Thiệp Cưới</b><small>Made in Vietnam</small></span>
      </a>
      <nav class="site-nav">
        <a class="nav-link" href="/mau-thiep"><LayoutTemplate size={16} /> Mẫu thiệp</a>
        <a class="nav-link" href="/checklist"><ListChecks size={16} /> Checklist</a>
        <a class="nav-link" href="/nghi-le"><ScrollText size={16} /> Nghi lễ</a>
        <a class="nav-link" href="/xem-ngay"><CalendarHeart size={16} /> Xem ngày cưới</a>
        <a class="nav-link" href="/mam-qua"><Gift size={16} /> Mâm quả</a>
        <a class="nav-link" href="/ngan-sach"><Wallet size={16} /> Ngân sách</a>
        <a class="nav-link nav-cta" href="#soan">Bắt đầu tạo thiệp</a>
      </nav>
    </header>

    <section class="hero">
      <div class="eyebrow">Trầu cau · Vu quy · Tân hôn</div>
      <h1>Tự tay làm thiệp cưới online<br />đẹp như studio</h1>
      <p>Điền thông tin, chọn mẫu yêu thích, rồi gửi link chia sẻ cho khách mời. Có đếm ngược ngày vui, bản đồ chỉ đường và xác nhận tham dự — tất cả miễn phí.</p>
      <div class="hero-cta">
        <a class="btn btn-primary" href="/mau-thiep"><LayoutTemplate size={18} /> Xem 12 mẫu thiệp</a>
        <a class="btn btn-ghost" href="#soan"><Heart size={18} /> Bắt đầu tạo ngay</a>
      </div>
      <div class="hero-trust">
        <span>✦ Miễn phí</span>
        <span>✦ Không cần đăng ký</span>
        <span>✦ Xong trong 5 phút</span>
        <span>✦ Song ngữ · QR mừng · In giấy</span>
      </div>
    </section>

    <main class="editor" id="soan">
      <!-- FORM -->
      <form class="card" id="form">
        <h2>Thông tin thiệp</h2>
        <p class="hint">Điền theo từng mục — mọi thay đổi hiện ngay ở khung xem trước. Chỉ <b>tên</b> &amp; <b>ngày cưới</b> là bắt buộc, phần còn lại tuỳ chọn.</p>
        <Button type="button" id="demoFill" variant="outline" size="md" class="mt-1 mb-5 w-full border-dashed text-primary hover:text-primary"><WandSparkles size={16} /> Điền thử dữ liệu mẫu (xem ngay thiệp hoàn chỉnh)</Button>

        <Accordion>
          <!-- 1 · Cặp đôi & ngày cưới -->
          <AccordionItem title="Cặp đôi & ngày cưới" hint="Thông tin cơ bản — bắt buộc" open>
            <Heart slot="icon" />
            <div class="grid gap-4 sm:grid-cols-2">
              <div class="flex flex-col gap-1.5">
                <Label for="groom">Tên chú rể <span class="text-primary">*</span></Label>
                <Input id="groom" name="groom" placeholder="Nguyễn Minh Đức" required />
              </div>
              <div class="flex flex-col gap-1.5">
                <Label for="bride">Tên cô dâu <span class="text-primary">*</span></Label>
                <Input id="bride" name="bride" placeholder="Trần Thuỳ Dương" required />
              </div>
            </div>
            <div class="flex flex-col gap-1.5">
              <Label for="weddingDate">Ngày &amp; giờ tổ chức <span class="text-primary">*</span></Label>
              <Input id="weddingDate" name="weddingDate" type="datetime-local" required />
            </div>
            <div class="flex flex-col gap-1.5">
              <Label for="photoUrl">Ảnh cưới <span class="text-muted-foreground font-normal">(tải lên hoặc dán link)</span></Label>
              <Input id="photoUrl" name="photoUrl" placeholder="https://... hoặc bấm Tải ảnh lên" />
              <img id="photoPreview" src="" alt="Xem trước ảnh cưới"
                class="hidden mt-1 h-28 w-48 rounded-xl object-cover border border-input shadow-sm [animation:photoIn_.35s_ease_both]" />
              <div>
                <button type="button" class="suggest-btn" id="photoUpload">📷 Tải ảnh lên</button>
                <input type="file" id="photoFile" accept="image/*" hidden />
              </div>
            </div>
            <div class="flex flex-col gap-1.5">
              <Label for="invitation">Lời mời</Label>
              <Textarea id="invitation" name="invitation" placeholder="Trân trọng kính mời quý vị tới chung vui cùng gia đình chúng tôi...">Trân trọng kính mời bạn đến chung vui trong ngày trọng đại của chúng tôi.</Textarea>
              <div>
                <button type="button" class="suggest-btn" data-target="invitation">✨ Gợi ý mẫu</button>
                <div class="suggest-list" data-for="invitation" hidden></div>
              </div>
            </div>
          </AccordionItem>

          <!-- 2 · Chọn mẫu thiệp -->
          <AccordionItem title="Chọn mẫu thiệp" hint="12 mẫu — đổi mẫu xem ngay bên cạnh" open>
            <LayoutTemplate slot="icon" />
            <div class="templates" id="templates">
              <label class="tpl active" data-tpl="truyen-thong">
                <input type="radio" name="template" value="truyen-thong" checked hidden />
                <span class="swatch t-truyen-thong">囍</span>
                <span>Truyền thống</span>
              </label>
              <label class="tpl" data-tpl="hien-dai">
                <input type="radio" name="template" value="hien-dai" hidden />
                <span class="swatch t-hien-dai">M &amp; D</span>
                <span>Hiện đại</span>
              </label>
              <label class="tpl" data-tpl="pastel">
                <input type="radio" name="template" value="pastel" hidden />
                <span class="swatch t-pastel">❀</span>
                <span>Pastel hoa lá</span>
              </label>
              <label class="tpl" data-tpl="hoang-gia">
                <input type="radio" name="template" value="hoang-gia" hidden />
                <span class="swatch t-hoang-gia">♛</span>
                <span>Hoàng gia</span>
              </label>
              <label class="tpl" data-tpl="xanh-la">
                <input type="radio" name="template" value="xanh-la" hidden />
                <span class="swatch t-xanh-la">❧</span>
                <span>Xanh lá</span>
              </label>
              <label class="tpl" data-tpl="do-ruou">
                <input type="radio" name="template" value="do-ruou" hidden />
                <span class="swatch t-do-ruou">♥</span>
                <span>Đỏ rượu</span>
              </label>
              <label class="tpl" data-tpl="anh-dao">
                <input type="radio" name="template" value="anh-dao" hidden />
                <span class="swatch t-anh-dao">❀</span>
                <span>Anh đào</span>
              </label>
              <label class="tpl" data-tpl="long-phung">
                <input type="radio" name="template" value="long-phung" hidden />
                <span class="swatch t-long-phung">龍</span>
                <span>Long Phụng</span>
              </label>
              <label class="tpl" data-tpl="mai-trang">
                <input type="radio" name="template" value="mai-trang" hidden />
                <span class="swatch t-mai-trang">梅</span>
                <span>Mai Trắng</span>
              </label>
              <label class="tpl" data-tpl="lam-ngoc">
                <input type="radio" name="template" value="lam-ngoc" hidden />
                <span class="swatch t-lam-ngoc">❖</span>
                <span>Lam Ngọc</span>
              </label>
              <label class="tpl" data-tpl="hong-kim">
                <input type="radio" name="template" value="hong-kim" hidden />
                <span class="swatch t-hong-kim">♡</span>
                <span>Hồng Kim</span>
              </label>
              <label class="tpl" data-tpl="luc-bao">
                <input type="radio" name="template" value="luc-bao" hidden />
                <span class="swatch t-luc-bao">❧</span>
                <span>Lục Bảo</span>
              </label>
            </div>
          </AccordionItem>

          <!-- 3 · Câu chuyện & Album -->
          <AccordionItem title="Câu chuyện & Album ảnh" hint="Chuyện tình, hành trình, album, nhạc, livestream">
            <Images slot="icon" />
            <div class="flex flex-col gap-1.5">
              <Label for="story">Chuyện tình <span class="text-muted-foreground font-normal">(không bắt buộc)</span></Label>
              <Textarea id="story" name="story" placeholder="Đôi dòng về hành trình của hai bạn..."></Textarea>
              <div>
                <button type="button" class="suggest-btn" data-target="story">✨ Gợi ý mẫu</button>
                <div class="suggest-list" data-for="story" hidden></div>
              </div>
            </div>
            <div class="flex flex-col gap-2">
              <Label>Hành trình tình yêu <span class="text-muted-foreground font-normal text-xs">(không bắt buộc)</span></Label>
              <textarea id="loveStory" name="loveStory" hidden aria-hidden="true"></textarea>
              <div id="loveStoryRows" class="flex flex-col gap-2"></div>
              <button type="button" id="addLoveMilestone"
                class="mt-0.5 inline-flex items-center gap-1.5 self-start rounded-lg border border-dashed border-input px-3 py-2 text-sm text-muted-foreground transition-colors hover:border-foreground hover:text-foreground">
                + Thêm mốc kỷ niệm
              </button>
            </div>
            <div class="flex flex-col gap-1.5">
              <Label for="gallery">Album ảnh cưới <span class="text-muted-foreground font-normal">(tối đa 12)</span></Label>
              <Textarea id="gallery" name="gallery" placeholder="Bấm Tải ảnh lên, hoặc dán link mỗi dòng 1 ảnh..."></Textarea>
              <div>
                <button type="button" class="suggest-btn" id="galleryUpload">📷 Tải ảnh lên (chọn nhiều)</button>
                <input type="file" id="galleryFile" accept="image/*" multiple hidden />
              </div>
              <div class="gallery-thumbs" id="galleryThumbs"></div>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              <div class="flex flex-col gap-1.5">
                <Label for="musicUrl">Nhạc nền <span class="text-muted-foreground font-normal">(.mp3)</span></Label>
                <Input id="musicUrl" name="musicUrl" placeholder="https://...nhac.mp3" />
              </div>
              <div class="flex flex-col gap-1.5">
                <Label for="livestreamUrl">Phát trực tiếp</Label>
                <Input id="livestreamUrl" name="livestreamUrl" placeholder="https://youtube.com/live/..." />
              </div>
            </div>
          </AccordionItem>

          <!-- 4 · Lịch trình & tiện ích -->
          <AccordionItem title="Lịch trình & tiện ích khách mời" hint="Lịch trình, dress code, hỏi đáp, lưu trú, sự kiện">
            <CalendarClock slot="icon" />
            <div class="flex flex-col gap-2">
              <Label>Lịch trình sự kiện <span class="text-muted-foreground font-normal text-xs">(không bắt buộc)</span></Label>
              <textarea id="timeline" name="timeline" hidden aria-hidden="true"></textarea>
              <div id="timelineRows" class="flex flex-col gap-2"></div>
              <button type="button" id="addTimelineRow"
                class="mt-0.5 inline-flex items-center gap-1.5 self-start rounded-lg border border-dashed border-input px-3 py-2 text-sm text-muted-foreground transition-colors hover:border-foreground hover:text-foreground">
                + Thêm mốc lịch trình
              </button>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              <div class="flex flex-col gap-1.5">
                <Label for="dressText">Trang phục (dress code)</Label>
                <Input id="dressText" name="dressText" placeholder="Trang phục lịch sự, tông pastel" />
              </div>
              <div class="flex flex-col gap-1.5">
                <Label>Màu chủ đạo <span class="text-muted-foreground font-normal text-xs">(tối đa 6)</span></Label>
                <input id="dressColors" name="dressColors" type="hidden" />
                <div id="colorSwatches" class="flex flex-wrap items-center gap-2">
                  <input type="color" id="colorPicker" class="sr-only" tabindex="-1" aria-label="Chọn màu" />
                  <button type="button" id="addColorSwatch"
                    class="flex h-8 w-8 items-center justify-center rounded-full border-2 border-dashed border-input text-muted-foreground transition-colors hover:border-foreground hover:text-foreground text-lg leading-none"
                    title="Thêm màu">+</button>
                </div>
              </div>
            </div>
            <div class="flex flex-col gap-2">
              <Label>Hỏi &amp; Đáp cho khách <span class="text-muted-foreground font-normal text-xs">(không bắt buộc)</span></Label>
              <textarea id="faq" name="faq" hidden aria-hidden="true"></textarea>
              <div id="faqRows" class="flex flex-col gap-2"></div>
              <button type="button" id="addFaqRow"
                class="mt-0.5 inline-flex items-center gap-1.5 self-start rounded-lg border border-dashed border-input px-3 py-2 text-sm text-muted-foreground transition-colors hover:border-foreground hover:text-foreground">
                + Thêm câu hỏi
              </button>
            </div>
            <div class="flex flex-col gap-2">
              <Label>Nơi lưu trú cho khách ở xa <span class="text-muted-foreground font-normal text-xs">(không bắt buộc)</span></Label>
              <textarea id="stays" name="stays" hidden aria-hidden="true"></textarea>
              <div id="staysRows" class="flex flex-col gap-2"></div>
              <button type="button" id="addStayRow"
                class="mt-0.5 inline-flex items-center gap-1.5 self-start rounded-lg border border-dashed border-input px-3 py-2 text-sm text-muted-foreground transition-colors hover:border-foreground hover:text-foreground">
                + Thêm nơi lưu trú
              </button>
            </div>
            <div class="flex flex-col gap-2">
              <Label>Sự kiện khác <span class="text-muted-foreground font-normal text-xs">(không bắt buộc)</span></Label>
              <textarea id="events" name="events" hidden aria-hidden="true"></textarea>
              <div id="eventsRows" class="flex flex-col gap-2"></div>
              <button type="button" id="addEventRow"
                class="mt-0.5 inline-flex items-center gap-1.5 self-start rounded-lg border border-dashed border-input px-3 py-2 text-sm text-muted-foreground transition-colors hover:border-foreground hover:text-foreground">
                + Thêm sự kiện
              </button>
            </div>
          </AccordionItem>

          <!-- 5 · Nhà trai -->
          <AccordionItem title="Nhà trai" hint="Gia đình & địa điểm nhà trai">
            <House slot="icon" />
            <div class="grid gap-4 sm:grid-cols-2">
              <div class="flex flex-col gap-1.5">
                <Label for="groomFather">Thân phụ (bố chú rể)</Label>
                <Input id="groomFather" name="groomFather" placeholder="Ông Nguyễn Văn A" />
              </div>
              <div class="flex flex-col gap-1.5">
                <Label for="groomMother">Thân mẫu (mẹ chú rể)</Label>
                <Input id="groomMother" name="groomMother" placeholder="Bà Lê Thị B" />
              </div>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              <div class="flex flex-col gap-1.5">
                <Label for="groomCeremony">Loại lễ</Label>
                <Select id="groomCeremony" name="groomCeremony">
                  <option value="">— Không hiển thị —</option>
                  <option value="Lễ Tân Hôn" selected>Lễ Tân Hôn (nhà trai)</option>
                  <option value="Lễ Thành Hôn">Lễ Thành Hôn</option>
                  <option value="Lễ Báo Hỷ">Lễ Báo Hỷ</option>
                </Select>
              </div>
              <div class="flex flex-col gap-1.5">
                <Label for="groomVenueName">Tên địa điểm / tư gia</Label>
                <Input id="groomVenueName" name="groomVenueName" placeholder="Tư gia nhà trai / Trung tâm tiệc cưới ..." />
              </div>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              <div class="flex flex-col gap-1.5">
                <Label for="groomTime">Thời gian</Label>
                <Input id="groomTime" name="groomTime" placeholder="11:00, Chủ nhật" />
              </div>
              <div class="flex flex-col gap-1.5">
                <Label for="groomMapUrl">Link Google Maps</Label>
                <Input id="groomMapUrl" name="groomMapUrl" placeholder="https://maps.google.com/..." />
              </div>
            </div>
            <div class="flex flex-col gap-1.5">
              <Label for="groomVenueAddress">Địa chỉ</Label>
              <Input id="groomVenueAddress" name="groomVenueAddress" placeholder="Số nhà, đường, phường, quận, tỉnh/TP" />
            </div>
          </AccordionItem>

          <!-- 6 · Nhà gái -->
          <AccordionItem title="Nhà gái" hint="Gia đình & địa điểm nhà gái">
            <House slot="icon" />
            <div class="grid gap-4 sm:grid-cols-2">
              <div class="flex flex-col gap-1.5">
                <Label for="brideFather">Thân phụ (bố cô dâu)</Label>
                <Input id="brideFather" name="brideFather" placeholder="Ông Trần Văn C" />
              </div>
              <div class="flex flex-col gap-1.5">
                <Label for="brideMother">Thân mẫu (mẹ cô dâu)</Label>
                <Input id="brideMother" name="brideMother" placeholder="Bà Phạm Thị D" />
              </div>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              <div class="flex flex-col gap-1.5">
                <Label for="brideCeremony">Loại lễ</Label>
                <Select id="brideCeremony" name="brideCeremony">
                  <option value="">— Không hiển thị —</option>
                  <option value="Lễ Vu Quy" selected>Lễ Vu Quy (nhà gái)</option>
                  <option value="Lễ Thành Hôn">Lễ Thành Hôn</option>
                  <option value="Lễ Báo Hỷ">Lễ Báo Hỷ</option>
                </Select>
              </div>
              <div class="flex flex-col gap-1.5">
                <Label for="brideVenueName">Tên địa điểm / tư gia</Label>
                <Input id="brideVenueName" name="brideVenueName" placeholder="Tư gia nhà gái / Nhà hàng ..." />
              </div>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              <div class="flex flex-col gap-1.5">
                <Label for="brideTime">Thời gian</Label>
                <Input id="brideTime" name="brideTime" placeholder="17:30, Thứ Bảy" />
              </div>
              <div class="flex flex-col gap-1.5">
                <Label for="brideMapUrl">Link Google Maps</Label>
                <Input id="brideMapUrl" name="brideMapUrl" placeholder="https://maps.google.com/..." />
              </div>
            </div>
            <div class="flex flex-col gap-1.5">
              <Label for="brideVenueAddress">Địa chỉ</Label>
              <Input id="brideVenueAddress" name="brideVenueAddress" placeholder="Số nhà, đường, phường, quận, tỉnh/TP" />
            </div>
          </AccordionItem>

          <!-- 7 · Hộp mừng cưới -->
          <AccordionItem title="Hộp mừng cưới" hint="QR chuyển khoản — không bắt buộc">
            <Gift slot="icon" />
            <label class="switch-row" for="giftEnabled">
              <span>
                <b>Bật hộp mừng cưới</b>
                <small>Hiện QR ngân hàng ở cuối thiệp cho khách <em>muốn</em> chuyển khoản mừng cưới. Để khách tự quét — tế nhị, không ép buộc.</small>
              </span>
              <input type="checkbox" id="giftEnabled" name="giftEnabled" />
              <span class="switch"></span>
            </label>
            <div id="giftFields" hidden class="flex flex-col gap-4">
              <div class="flex flex-col gap-1.5">
                <Label for="giftNote">Lời dẫn <span class="text-muted-foreground font-normal">(tuỳ chọn)</span></Label>
                <Input id="giftNote" name="giftNote" placeholder="Sự hiện diện của bạn là món quà quý giá nhất với chúng tôi." />
              </div>
              <div class="gift-side">
                <div class="gift-side-title">Tài khoản nhà trai (chú rể)</div>
                <div class="grid gap-4 sm:grid-cols-2">
                  <div class="flex flex-col gap-1.5">
                    <Label for="giftGroomBank">Ngân hàng</Label>
                    <Select id="giftGroomBank" name="giftGroomBank"><option value="">— Chọn ngân hàng —</option></Select>
                  </div>
                  <div class="flex flex-col gap-1.5">
                    <Label for="giftGroomAccount">Số tài khoản</Label>
                    <Input id="giftGroomAccount" name="giftGroomAccount" inputmode="numeric" placeholder="0123456789" />
                  </div>
                </div>
                <div class="flex flex-col gap-1.5 mt-3">
                  <Label for="giftGroomName">Chủ tài khoản</Label>
                  <Input id="giftGroomName" name="giftGroomName" placeholder="NGUYEN MINH DUC" />
                </div>
              </div>
              <div class="gift-side">
                <div class="gift-side-title">Tài khoản nhà gái (cô dâu)</div>
                <div class="grid gap-4 sm:grid-cols-2">
                  <div class="flex flex-col gap-1.5">
                    <Label for="giftBrideBank">Ngân hàng</Label>
                    <Select id="giftBrideBank" name="giftBrideBank"><option value="">— Chọn ngân hàng —</option></Select>
                  </div>
                  <div class="flex flex-col gap-1.5">
                    <Label for="giftBrideAccount">Số tài khoản</Label>
                    <Input id="giftBrideAccount" name="giftBrideAccount" inputmode="numeric" placeholder="0123456789" />
                  </div>
                </div>
                <div class="flex flex-col gap-1.5 mt-3">
                  <Label for="giftBrideName">Chủ tài khoản</Label>
                  <Input id="giftBrideName" name="giftBrideName" placeholder="TRAN THUY DUONG" />
                </div>
              </div>
            </div>
          </AccordionItem>

          <!-- 8 · Hiệu ứng & chế độ -->
          <AccordionItem title="Hiệu ứng & chế độ thiệp" hint="Mở thiệp, Save the Date, lời cảm ơn">
            <Sparkles slot="icon" />
            <label class="switch-row" for="introEnabled">
              <span>
                <b>Hiệu ứng mở thiệp</b>
                <small>Màn mở đầu kiểu "phong bì": tên cô dâu chú rể + nút "Mở thiệp", rồi hé lộ nội dung.</small>
              </span>
              <input type="checkbox" id="introEnabled" name="introEnabled" checked />
              <span class="switch"></span>
            </label>
            <label class="switch-row" for="saveTheDate">
              <span>
                <b>Chế độ "Save the Date"</b>
                <small>Thiệp báo trước (gửi sớm 6–8 tháng): chỉ nhấn tên &amp; ngày cưới, ẩn RSVP/hộp mừng — thiệp mời chính thức gửi sau.</small>
              </span>
              <input type="checkbox" id="saveTheDate" name="saveTheDate" />
              <span class="switch"></span>
            </label>
            <label class="switch-row" for="thankYouEnabled">
              <span>
                <b>Chế độ cảm ơn (sau cưới)</b>
                <small>Bật sau tiệc: hiện lời cảm ơn ở đầu thiệp và mời khách xem/đóng góp ảnh kỷ niệm.</small>
              </span>
              <input type="checkbox" id="thankYouEnabled" name="thankYouEnabled" />
              <span class="switch"></span>
            </label>
            <div class="flex flex-col gap-1.5" id="thankYouFields" hidden>
              <Label for="thankYouMsg">Lời cảm ơn</Label>
              <Textarea id="thankYouMsg" name="thankYouMsg" placeholder="Cảm ơn quý vị đã đến chung vui và gửi lời chúc phúc tới chúng tôi trong ngày trọng đại!">Cảm ơn quý vị đã đến chung vui và dành cho chúng tôi những lời chúc tốt đẹp nhất trong ngày trọng đại!</Textarea>
            </div>
          </AccordionItem>
        </Accordion>

        <div class="err-inline" id="formErr"></div>
        <Button id="createBtn" type="submit" variant="primary" size="lg" class="mt-5 w-full text-base">
          ✦ Tạo thiệp &amp; lấy link chia sẻ
        </Button>
      </form>

      <!-- PREVIEW -->
      <aside class="preview-pane">
        <div class="preview-tabs" id="previewTabs">
          <button type="button" class="ptab active" data-side="">Chung</button>
          <button type="button" class="ptab" data-side="trai">Nhà trai</button>
          <button type="button" class="ptab" data-side="gai">Nhà gái</button>
        </div>
        <div class="preview-frame">
          <iframe id="preview" src="/invite.html?preview=1" title="Xem trước thiệp"></iframe>
        </div>
        <div class="preview-caption">Xem trước trực tiếp · chọn tab để xem từng phiên bản thiệp</div>
      </aside>
    </main>

    <footer class="site-footer">
      Made with ❤ for Vietnamese weddings · Thiệp Cưới Online
    </footer>

    <!-- Draft autosave toast -->
    <div id="draftToast" role="status" aria-live="polite"
      class="draft-toast pointer-events-none fixed bottom-20 left-1/2 rounded-full bg-black/70 px-4 py-1.5 text-[13px] text-white z-50">
      ✓ Bản nháp đã lưu
    </div>
  </div>

  <!-- Result modal -->
  <div class="overlay" id="overlay">
    <div class="modal">
      <span class="sigil" style="margin:0 auto 6px;display:grid;width:50px;height:50px;border-radius:50%;background:linear-gradient(145deg,#b5232a,#8c171d);color:#ffe9b8;place-items:center;font-size:24px">囍</span>
      <h3>Thiệp đã sẵn sàng!</h3>
      <p>Gửi link này cho khách mời của bạn.</p>
      <div id="qrbox"></div>
      <p class="note">👪 <b>Mua 1 được 3 thiệp</b> — chọn link phù hợp để gửi:</p>
      <div class="linkrow">
        <input id="shareLink" readonly />
        <button class="btn btn-primary" id="copyShare" type="button">Chung</button>
      </div>
      <div class="linkrow">
        <input id="linkTrai" readonly />
        <button class="btn btn-ghost" id="copyTrai" type="button">Nhà trai</button>
      </div>
      <div class="linkrow">
        <input id="linkGai" readonly />
        <button class="btn btn-ghost" id="copyGai" type="button">Nhà gái</button>
      </div>
      <div class="share-row">
        <button class="btn btn-ghost share-btn" id="shareNative" type="button" aria-label="Chia sẻ qua Zalo, Messenger…">📤 Chia sẻ</button>
        <a class="btn btn-ghost share-btn share-fb" id="shareFb" target="_blank" rel="noopener" aria-label="Chia sẻ lên Facebook">f Facebook</a>
      </div>
      <p class="note">📱 Nút <b>Chia sẻ</b> mở Zalo / Messenger… (trên điện thoại)</p>
      <a class="btn btn-ghost btn-block" id="openInvite" target="_blank" style="margin:4px 0 8px">Mở thiệp ↗</a>
      <a class="btn btn-ghost btn-block" id="openPrint" target="_blank" style="margin:0 0 10px">🖨️ Bản thiệp in giấy (PDF) ↗</a>
      <p class="note">📋 Link <span class="danger">quản lý & RSVP</span> — đăng nhập để quản lý:</p>
      <div class="linkrow">
        <input id="manageLink" readonly />
        <button class="btn btn-ghost" id="copyManage" type="button">Copy</button>
      </div>
      <a class="btn btn-ghost btn-block" href="/tai-khoan" style="margin-top:4px">Tới trang tài khoản ↗</a>
      <button class="btn btn-ghost btn-block" id="closeModal" type="button" style="margin-top:8px">Tạo thiệp khác</button>
    </div>
  </div>

  <div class="toast" id="toast"></div>

  <script is:inline src="/js/qrcode.js"></script>
  <script is:inline src="/js/vietqr.js"></script>
  <script is:inline src="/js/editor.js"></script>
  <script is:inline>if ('serviceWorker' in navigator) { window.addEventListener('load', function () { navigator.serviceWorker.register('/sw.js').catch(function () {}); }); }</script>
</body>
</html>
