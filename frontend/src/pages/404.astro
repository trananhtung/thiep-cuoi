---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Không tìm thấy trang — Thiệp Cưới Online">
  <section class="py-24 text-center">
    <div class="not-found-icon">💌</div>
    <h1 class="not-found-code font-display text-[clamp(72px,12vw,120px)] font-extrabold text-primary">404</h1>
    <p class="not-found-msg mt-3 text-brand-muted">Trang bạn tìm không tồn tại.</p>
    <a href="/" class="not-found-btn mt-6 inline-block rounded-full bg-primary px-6 py-3 font-semibold text-[#ffe9b8] no-underline transition hover:opacity-90">← Về trang chủ</a>
  </section>
</Layout>

<style>
  @keyframes iconFloat {
    0%, 100% { transform: translateY(0) rotate(-4deg); }
    50%       { transform: translateY(-10px) rotate(4deg); }
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: none; }
  }
  .not-found-icon { font-size: 64px; animation: iconFloat 3s ease-in-out infinite, fadeUp .5s ease both; }
  .not-found-code { animation: fadeUp .45s ease .1s both; }
  .not-found-msg  { animation: fadeUp .45s ease .2s both; }
  .not-found-btn  { animation: fadeUp .45s ease .32s both; }
  @media (prefers-reduced-motion: reduce) {
    .not-found-icon { animation: fadeUp .5s ease both; }
    .not-found-code, .not-found-msg, .not-found-btn { animation: none; }
  }
</style>
