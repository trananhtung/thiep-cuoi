---
interface Props { size?: number; class?: string }
const { size = 24, class: className } = Astro.props;
---
<!-- Bút Lông — bút thư pháp truyền thống, biểu tượng nghệ thuật viết chữ Việt -->
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width={size} height={size}
  fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
  class={className} aria-hidden="true">
  <!-- Cán bút (nghiêng 45°) -->
  <line x1="18" y1="4" x2="9" y2="13"/>
  <!-- Kẹp bút (ferrule) -->
  <line x1="8.3" y1="12.3" x2="10.7" y2="14.7"/>
  <!-- Đầu bút lông (hình tam giác nhọn) -->
  <path d="M9 13C7 14.5 5 17 6 19C8 19 10 17 10.5 15.5L9 13Z"/>
  <!-- Nét mực (thư pháp đang viết) -->
  <path d="M3 19.5Q5 18 7 20"/>
  <path d="M2.5 22Q4.5 21 6 22.5"/>
</svg>
