---
interface Props { size?: number; class?: string }
const { size = 24, class: className } = Astro.props;
---
<!-- Âm Lịch — lịch âm với biểu tượng trăng rằm, xem ngày tốt lành -->
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width={size} height={size}
  fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
  class={className} aria-hidden="true">
  <!-- Quyển lịch -->
  <rect x="3" y="5" width="18" height="16" rx="2"/>
  <!-- Đường kẻ ngang chia đầu lịch -->
  <line x1="3" y1="10" x2="21" y2="10"/>
  <!-- Gáy lịch trên -->
  <line x1="8" y1="3" x2="8" y2="7"/>
  <line x1="16" y1="3" x2="16" y2="7"/>
  <!-- Trăng rằm (mặt trăng đầy trong âm lịch) -->
  <circle cx="12" cy="15" r="3.5"/>
</svg>
