---
interface Props { size?: number; class?: string }
const { size = 24, class: className } = Astro.props;
---
<!-- Cuộn Thư — biểu tượng mẫu thiệp, nghi lễ truyền thống -->
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width={size} height={size}
  fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
  class={className} aria-hidden="true">
  <!-- Thân cuộn -->
  <rect x="7" y="4" width="10" height="16" rx="1"/>
  <!-- Cuộn đầu trên (trái & phải) -->
  <path d="M7 4C7 2.3 10 2.3 10 4"/>
  <path d="M17 4C17 2.3 14 2.3 14 4"/>
  <!-- Cuộn đầu dưới -->
  <path d="M7 20C7 21.7 10 21.7 10 20"/>
  <path d="M17 20C17 21.7 14 21.7 14 20"/>
  <!-- Dòng chữ -->
  <line x1="9.5" y1="9" x2="14.5" y2="9"/>
  <line x1="9.5" y1="12" x2="14.5" y2="12"/>
  <line x1="9.5" y1="15" x2="13" y2="15"/>
</svg>
