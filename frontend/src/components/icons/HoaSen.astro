---
interface Props { size?: number; class?: string }
const { size = 24, class: className } = Astro.props;
---
<!-- Hoa Sen (Lotus) — biểu tượng tình yêu thuần khiết trong văn hóa Việt -->
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width={size} height={size}
  fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
  class={className} aria-hidden="true">
  <!-- Cánh giữa -->
  <path d="M12 17C10.5 13 10.5 8 12 6C13.5 8 13.5 13 12 17Z"/>
  <!-- Cánh trái -->
  <path d="M12 17C9 13 7.5 9 9 7C11 9 11 14 12 17Z"/>
  <!-- Cánh phải -->
  <path d="M12 17C15 13 16.5 9 15 7C13 9 13 14 12 17Z"/>
  <!-- Cuống sen -->
  <line x1="12" y1="17" x2="12" y2="21"/>
  <!-- Mặt nước -->
  <path d="M9 21.5Q12 20.5 15 21.5"/>
</svg>
