---
import Ornament from './Ornament.astro';
import CuonThu from './icons/CuonThu.astro';
import DanhSach from './icons/DanhSach.astro';
import DenLong from './icons/DenLong.astro';
import AmLich from './icons/AmLich.astro';
import MamQua from './icons/MamQua.astro';
import DongTien from './icons/DongTien.astro';
---
<header class="site-header mx-auto flex max-w-[1180px] flex-wrap items-center justify-between gap-4 px-[22px] py-5">
  <a href="/" class="flex items-center gap-3 text-ink no-underline">
    <Ornament />
    <span>
      <b class="block font-[var(--font-display)] text-[22px] tracking-wide">Thiệp Cưới</b>
      <small class="block text-[12px] uppercase tracking-[2px] text-brand-muted">Made in Vietnam</small>
    </span>
  </a>
  <nav id="main-nav" class="flex flex-wrap items-center gap-2.5">
    <a href="/mau-thiep" data-nav-href="/mau-thiep"
      class="nav-link inline-flex items-center gap-1.5 rounded-full border border-line px-3 py-1.5 text-sm text-ink no-underline transition-colors duration-150 hover:border-gold">
      <CuonThu size={15} /> Mẫu thiệp
    </a>
    <a href="/checklist" data-nav-href="/checklist"
      class="nav-link inline-flex items-center gap-1.5 rounded-full border border-line px-3 py-1.5 text-sm text-ink no-underline transition-colors duration-150 hover:border-gold">
      <DanhSach size={15} /> Checklist
    </a>
    <a href="/nghi-le" data-nav-href="/nghi-le"
      class="nav-link inline-flex items-center gap-1.5 rounded-full border border-line px-3 py-1.5 text-sm text-ink no-underline transition-colors duration-150 hover:border-gold">
      <DenLong size={15} /> Nghi lễ
    </a>
    <a href="/xem-ngay" data-nav-href="/xem-ngay"
      class="nav-link inline-flex items-center gap-1.5 rounded-full border border-line px-3 py-1.5 text-sm text-ink no-underline transition-colors duration-150 hover:border-gold">
      <AmLich size={15} /> Xem ngày cưới
    </a>
    <a href="/mam-qua" data-nav-href="/mam-qua"
      class="nav-link inline-flex items-center gap-1.5 rounded-full border border-line px-3 py-1.5 text-sm text-ink no-underline transition-colors duration-150 hover:border-gold">
      <MamQua size={15} /> Mâm quả
    </a>
    <a href="/ngan-sach" data-nav-href="/ngan-sach"
      class="nav-link inline-flex items-center gap-1.5 rounded-full border border-line px-3 py-1.5 text-sm text-ink no-underline transition-colors duration-150 hover:border-gold">
      <DongTien size={15} /> Ngân sách
    </a>
  </nav>
</header>

<style>
  @keyframes headerIn {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: none; }
  }
  .site-header { animation: headerIn .35s ease both; }
  @media (prefers-reduced-motion: reduce) { .site-header { animation: none; } }
</style>

<script>
  function setActiveNav() {
    const path = window.location.pathname.replace(/\/$/, '');
    document.querySelectorAll<HTMLAnchorElement>('a[data-nav-href]').forEach((a) => {
      const match = path === (a.dataset.navHref ?? '').replace(/\/$/, '');
      a.classList.toggle('border-gold-deep', match);
      a.classList.toggle('bg-gold-deep', match);
      a.classList.toggle('font-semibold', match);
      a.classList.toggle('text-white', match);
      a.classList.toggle('border-line', !match);
      a.classList.toggle('text-ink', !match);
      a.classList.toggle('hover:border-gold', !match);
      a.toggleAttribute('aria-current', match);
    });
  }
  setActiveNav();
  document.addEventListener('astro:page-load', setActiveNav);
</script>
