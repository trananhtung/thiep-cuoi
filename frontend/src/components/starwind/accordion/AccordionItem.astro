---
// Progressive-disclosure section built on native <details> — works with zero JS
// and keeps collapsed fields in the DOM so the form still submits everything.
interface Props {
  title: string;
  hint?: string;
  open?: boolean;
  class?: string;
}

const { title, hint, open = false, class: className } = Astro.props;
const hasIcon = Astro.slots.has("icon");
---

<details
  class:list={[
    "group/acc overflow-hidden rounded-card border border-line bg-card shadow-xs",
    "transition-colors open:border-primary/30 open:shadow-sm",
    className,
  ]}
  open={open}
  data-slot="accordion-item"
>
  <summary
    class="flex cursor-pointer list-none items-center gap-3 px-4 py-3.5 select-none [&::-webkit-details-marker]:hidden hover:bg-muted/50 transition-colors"
  >
    {
      hasIcon && (
        <span class="grid size-9 shrink-0 place-items-center rounded-full bg-primary/8 text-primary [&_svg]:size-[18px] group-open/acc:bg-primary/12">
          <slot name="icon" />
        </span>
      )
    }
    <span class="flex min-w-0 flex-col">
      <span class="font-semibold text-foreground">{title}</span>
      {hint && <span class="truncate text-xs text-muted-foreground">{hint}</span>}
    </span>
    <svg
      class="ml-auto size-5 shrink-0 text-muted-foreground transition-transform duration-200 group-open/acc:rotate-180"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="m6 9 6 6 6-6"></path>
    </svg>
  </summary>
  <div class="flex flex-col gap-4 border-t border-line px-4 pt-4 pb-5">
    <slot />
  </div>
</details>
